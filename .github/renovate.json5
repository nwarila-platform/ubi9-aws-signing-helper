{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  // Renovate config for nwarila-platform/ubi9-aws-signing-helper. Keep Actions
  // pinned by digest; surface the UBI base pins and the from-source FIPS Go
  // builder pin for review. The Go builder is capped below 1.26 so the validated
  // GOFIPS140 Cryptographic Module v1.0.0 (CMVP #5247) is never bumped out from
  // under the build.
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],

  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",

  "enabledManagers": [
    "github-actions",
    "custom.regex"
  ],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.ya?ml$/",
        "/^docs/.*\\.md$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?\\s+\\w+(?:_VERSION)?:\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      // The FIPS-from-source Go builder image is carried in the reviewed image
      // manifest as application.build.go_image (tag@sha256). Track it so Renovate
      // proposes both a new tag and digest, subject to the <1.26.0 cap below.
      "customType": "regex",
      "managerFilePatterns": [
        "/^examples/.*\\.json$/",
        "/image-manifest\\.json$/"
      ],
      "matchStrings": [
        "\"go_image\":\\s*\"golang:(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]{64})\""
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "golang",
      "versioningTemplate": "docker"
    },
    {
      // Track the digest-pinned UBI 9 builder (ubi-minimal) and runtime
      // (ubi-micro) bases wherever they appear by bare digest reference. Red Hat
      // floating tags are not used at runtime, so currentValue is held at the
      // sentinel "latest" and Renovate only ever proposes a new digest.
      "customType": "regex",
      "managerFilePatterns": [
        "/^examples/.*\\.json$/",
        "/image-manifest\\.json$/"
      ],
      "matchStrings": [
        "\"(?<depName>registry\\.access\\.redhat\\.com/ubi9/ubi-(?:minimal|micro))@(?<currentDigest>sha256:[a-f0-9]{64})\""
      ],
      "datasourceTemplate": "docker",
      "currentValueTemplate": "latest",
      "versioningTemplate": "redhat"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["actions/checkout"],
      "groupName": "actions/checkout",
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchDepNames": ["actions/setup-python"],
      "groupName": "actions/setup-python",
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchDatasources": ["docker"],
      "matchDepNames": ["golang"],
      "groupName": "golang FIPS build image",
      "semanticCommitType": "deps",
      "semanticCommitScope": "deps",
      // The GOFIPS140 validated Go Cryptographic Module v1.0.0 (CMVP #5247) is
      // selectable in Go 1.24 and 1.25. Go 1.26 introduces a not-yet-validated
      // v1.26.0 module, so capping below 1.26.0 is the fail-closed FIPS guard:
      // Renovate must never bump the builder past the last Go release whose
      // snapshot maps to a validated module.
      "allowedVersions": "<1.26.0"
    },
    {
      "matchDatasources": ["docker"],
      "matchDepNames": [
        "registry.access.redhat.com/ubi9/ubi-minimal",
        "registry.access.redhat.com/ubi9/ubi-micro"
      ],
      "groupName": "ubi9 base images",
      "versioning": "redhat",
      "semanticCommitType": "deps"
    }
  ]
}
