{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NWarila/ubi9-application-template/contracts/image-manifest.schema.json",
  "title": "UBI 9 application image manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "image",
    "base",
    "dnf",
    "application",
    "runtime",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "platforms"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "rhel_version": {
          "type": "string",
          "pattern": "^9(\\.[0-9]+)?$"
        },
        "platforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^linux/(amd64|arm64)$"
          },
          "uniqueItems": true
        }
      }
    },
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builder", "runtime"],
      "properties": {
        "builder": {
          "type": "string",
          "pattern": "^.+@sha256:[a-f0-9]{64}$"
        },
        "runtime": {
          "type": "string",
          "pattern": "^.+@sha256:[a-f0-9]{64}$"
        }
      }
    },
    "dnf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packages"],
      "properties": {
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._+-]+$"
          },
          "uniqueItems": true
        },
        "repos": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9._-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "application": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "binary_path", "verification"],
      "allOf": [
        {
          "if": {
            "required": ["source"],
            "properties": { "source": { "const": "vendor-release-binary" } }
          },
          "then": { "required": ["name", "version", "artifacts"] }
        },
        {
          "comment": "From-source builds (compiled inside the Dockerfile, e.g. the FIPS-from-source aws-signing-helper) carry build provenance under application.build instead of a prebuilt artifacts[] with committed SHA256s.",
          "if": {
            "required": ["source"],
            "properties": { "source": { "const": "go-binary" } }
          },
          "then": { "required": ["build"] }
        }
      ],
      "properties": {
        "source": {
          "enum": ["go-binary", "vendor-release-binary", "static-binary", "other"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "binary_path": {
          "type": "string",
          "pattern": "^/.+"
        },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "required": ["go_version", "gofips140", "cgo_enabled", "source_repo", "source_ref"],
          "properties": {
            "go_version": { "type": "string", "minLength": 1 },
            "go_image": { "type": "string", "pattern": "^.+@sha256:[a-f0-9]{64}$" },
            "gofips140": { "type": "string", "minLength": 1 },
            "cgo_enabled": { "type": "string", "enum": ["0", "1"] },
            "godebug": { "type": "string", "minLength": 1 },
            "source_repo": { "type": "string", "minLength": 1 },
            "source_ref": { "type": "string", "minLength": 1 }
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["platform", "path", "sha256"],
            "properties": {
              "platform": {
                "type": "string",
                "pattern": "^linux/(amd64|arm64)$"
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[^/].*",
                "not": {
                  "anyOf": [
                    {
                      "pattern": "(^|/)\\.\\.(/|$)"
                    },
                    {
                      "pattern": "/$"
                    }
                  ]
                }
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": {
              "enum": ["checksum", "checksum-signature", "sigstore-bundle", "pgp-signature", "none"]
            },
            "checksum_url": {
              "type": "string"
            },
            "signature_url": {
              "type": "string"
            },
            "public_key_url": {
              "type": "string"
            },
            "certificate_identity": {
              "type": "string"
            },
            "certificate_oidc_issuer": {
              "type": "string"
            },
            "note": {
              "type": "string"
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user", "entrypoint", "forbidden_executables"],
      "properties": {
        "user": {
          "type": "string",
          "not": {
            "enum": ["", "0", "0:0", "root"]
          }
        },
        "entrypoint": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "forbidden_executables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^/.+"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "buildkit-sbom",
              "buildkit-provenance",
              "github-artifact-attestation",
              "cosign-signature",
              "runtime-hardening"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
